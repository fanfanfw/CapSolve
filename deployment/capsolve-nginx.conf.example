# Phase 5 proxy-trust design artifact. Phase 8 must install the final unit files.
# nginx must be built with ngx_http_realip_module. The tunnel must overwrite
# CF-Connecting-IP; this socket is inaccessible to ordinary local processes.
error_log /dev/null crit;
#
# Permission lifecycle: create /run/capsolve/ingress root:root 0700, start nginx,
# then run secure_nginx_ingress.py as root with nginx master uid 0. It verifies
# the root-owned inode, changes it to root:cloudflared 0660, and only then opens the
# directory to root:cloudflared 0710. cloudflared must start after this succeeds.
#   /run/capsolve/ingress                   root:cloudflared 0710
#   /run/capsolve/ingress/cloudflared.sock root:cloudflared 0660
#   /run/capsolve/uvicorn                 capsolve-api:capsolve-nginx 0770
#   /run/capsolve/uvicorn/api.sock        capsolve-api:capsolve-nginx 0660
# nginx has supplementary group capsolve-nginx; capsolve-api uses that primary
# group and worker is not a member. UVICORN_SOCKET_GID is the numeric group id.
# No TCP/public listen directive is permitted for either hop.

# Reject before real-ip processing unless the canonical header is a complete
# IPv4/IPv6 candidate. nginx realip then performs the actual IP parse; malformed
# candidates leave $remote_addr as "unix:" and fail the second map.
map $http_cf_connecting_ip $capsolve_cf_candidate {
    default "";
    "~^(?:(?:25[0-5]|2[0-4][0-9]|1[0-9]{2}|[1-9]?[0-9])\\.){3}(?:25[0-5]|2[0-4][0-9]|1[0-9]{2}|[1-9]?[0-9])$" $http_cf_connecting_ip;
    "~^(?:(?:[0-9A-Fa-f]{1,4}:){7}[0-9A-Fa-f]{1,4}|(?:[0-9A-Fa-f]{1,4}:){1,7}:|(?:[0-9A-Fa-f]{1,4}:){1,6}:[0-9A-Fa-f]{1,4}|(?:[0-9A-Fa-f]{1,4}:){1,5}(?::[0-9A-Fa-f]{1,4}){1,2}|(?:[0-9A-Fa-f]{1,4}:){1,4}(?::[0-9A-Fa-f]{1,4}){1,3}|(?:[0-9A-Fa-f]{1,4}:){1,3}(?::[0-9A-Fa-f]{1,4}){1,4}|(?:[0-9A-Fa-f]{1,4}:){1,2}(?::[0-9A-Fa-f]{1,4}){1,5}|[0-9A-Fa-f]{1,4}:(?:(?::[0-9A-Fa-f]{1,4}){1,6})|:(?:(?::[0-9A-Fa-f]{1,4}){1,7}|:)|::(?:ffff(?::0{1,4})?:)?(?:(?:25[0-5]|2[0-4][0-9]|1[0-9]{2}|[1-9]?[0-9])\\.){3}(?:25[0-5]|2[0-4][0-9]|1[0-9]{2}|[1-9]?[0-9])|(?:[0-9A-Fa-f]{1,4}:){1,4}:(?:(?:25[0-5]|2[0-4][0-9]|1[0-9]{2}|[1-9]?[0-9])\\.){3}(?:25[0-5]|2[0-4][0-9]|1[0-9]{2}|[1-9]?[0-9]))$" $http_cf_connecting_ip;
}

set_real_ip_from unix:;
real_ip_header CF-Connecting-IP;
real_ip_recursive off;
limit_req_zone $capsolve_client_ip zone=capsolve_api:10m rate=5r/s;

map $remote_addr $capsolve_client_ip {
    default "";
    "~^(?:(?:25[0-5]|2[0-4][0-9]|1[0-9]{2}|[1-9]?[0-9])\\.){3}(?:25[0-5]|2[0-4][0-9]|1[0-9]{2}|[1-9]?[0-9])$" $remote_addr;
    "~^[0-9A-Fa-f:.]+$" $remote_addr;
}

upstream capsolve_uvicorn {
    server unix:/run/capsolve/uvicorn/api.sock;
}

server {
    listen unix:/run/capsolve/ingress/cloudflared.sock;
    server_name <REQUIRED_CAPSOLVE_HOSTNAME>;
    access_log off;

    if ($capsolve_cf_candidate = "") { return 403; }
    if ($capsolve_client_ip = "") { return 403; }

    location / {
        access_log off;
        limit_req zone=capsolve_api burst=20 nodelay;
        proxy_connect_timeout 5s;
        proxy_send_timeout 30s;
        proxy_read_timeout 30s;
        proxy_pass http://capsolve_uvicorn;
        proxy_set_header Host $host;
        proxy_set_header Connection "";
        proxy_set_header Forwarded "";
        proxy_set_header X-Forwarded-For $capsolve_client_ip;
        proxy_set_header X-Forwarded-Proto https;
        proxy_set_header X-Real-IP "";
        proxy_set_header CF-Connecting-IP "";
    }

    location = /api/solve/ {
        access_log off;
        limit_req zone=capsolve_api burst=2 nodelay;
        proxy_connect_timeout 5s;
        proxy_send_timeout 180s;
        proxy_read_timeout 180s;
        proxy_pass http://capsolve_uvicorn;
        proxy_set_header Host $host;
        proxy_set_header Connection "";
        proxy_set_header Forwarded "";
        proxy_set_header X-Forwarded-For $capsolve_client_ip;
        proxy_set_header X-Forwarded-Proto https;
        proxy_set_header X-Real-IP "";
        proxy_set_header CF-Connecting-IP "";
    }
}
