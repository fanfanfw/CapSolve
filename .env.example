ENVIRONMENT=development

LOCAL_POST_URL=https://example.com/api/endpoint
SOLVER_TIMEOUT=45
LOCAL_POST_TIMEOUT=30
TURNSTILE_SITEKEY=your-turnstile-sitekey
TURNSTILE_SITEURL=https://example.com/page-with-turnstile

# Dynamic BUDI95 config
BUDI95_AUTO_RESOLVE=true
BUDI95_CONFIG_URL=https://www.budirakyat.gov.my/eligibility-check
BUDI95_CONFIG_CACHE_SECONDS=1800
BUDI95_CONFIG_FETCH_TIMEOUT=10
BUDI95_FORCE_ENV_CONFIG=false
BUDI95_CONFIG_CACHE_FILE=/tmp/capsolve_budi95_config.json

# Development binds loopback TCP only. Production removes API_HOST and uses the
# absolute UVICORN_UDS path provisioned with nginx-group directory permissions.
API_HOST=127.0.0.1
API_PORT=8191
# PORT=8191
# UVICORN_UDS=/run/capsolve/uvicorn/api.sock
UVICORN_SOCKET_MODE=0660
# Production numeric parent creator group (capsolve) and socket consumer group (capsolve-nginx).
# UVICORN_SOCKET_PARENT_GID=<REQUIRED_CAPSOLVE_GROUP_ID>
# UVICORN_SOCKET_GID=<REQUIRED_NGINX_GROUP_ID>
API_KEY=development-only-change-me
# API_KEYS=old-key,new-key
API_IP_ALLOWLIST=*
ALLOWED_HOSTS=localhost,127.0.0.1
API_DOCS_ENABLED=true
# Direct trusted peer IP/CIDR list for native Uvicorn X-Forwarded-* handling.
FORWARDED_ALLOW_IPS=127.0.0.1,::1

ENABLE_XVFB_VIRTUAL_DISPLAY=false
DISPLAY=:99
XVFB_DISPLAY=:99
TS_PROFILE_DIR=/tmp/capsolve_profiles
MAX_WORKERS=1
GLOBAL_CHROME_SLOTS=1
SYNC_QUEUE_MAX_WAITING=0

# Postgres
DB_HOST=localhost
DB_PORT=5432
DB_NAME=capsolve
DB_USER=postgres
DB_PASSWORD=
DB_CONNECT_TIMEOUT=3

# Async job worker
JOB_QUEUE_CAPACITY=100
JOB_QUEUE_RETRY_AFTER_SECONDS=60
# Per resolved client IP. Set 0 to disable application-level limiting.
BUDI95_SUBMIT_RATE_LIMIT_PER_MINUTE=30
BUDI95_READ_RATE_LIMIT_PER_MINUTE=120
JOB_BATCH_LIMIT=5
JOB_MAX_ATTEMPTS=3
JOB_RESET_STALE_MINUTES=30
# Development default/approved value; production must set explicitly. Valid range: 1..8760 hours.
JOB_RETENTION_HOURS=24
# Valid range: 1..10000 rows.
PURGE_BATCH_LIMIT=1000
# Production preflight reads backup retention from protected evidence, not this development file.

# Optional
# CHROME_PATH=/usr/bin/google-chrome
# CHROME_ARGS=--disable-gpu
